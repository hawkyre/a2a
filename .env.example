# Harness env API (the a2a-hack CLI on your host)
ENV_API_URL=http://host.docker.internal:8090
CS_AGENT_URL=http://host.docker.internal:8090/cs-agent

# Per-service env API tokens (must match the harness's tokens; these are the
# harness dev defaults)
PERSONAL_ENV_API_TOKEN=dev-user-token
CS_ENV_API_TOKEN=dev-agent-token

# Model — gemini-3.5-flash is required (see "Models" in the README)
MODEL=gemini-3.5-flash

# Vertex AI auth: an API key created in your GCP project (Vertex AI Agent
# Platform -> API keys), so usage runs on your Google Cloud credits.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_API_KEY=...
